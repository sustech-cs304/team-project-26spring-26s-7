{
  "app": {
    // ===========================================================
    // signingConfigs:
    //   - "default"        ← 当前 debug / 真机调试用（testDebug.p7b + test.cer）
    //   - "releaseConfig"  ← AppGallery 上架打 release 包时切换到这个
    //                        （release_testRelease.p7b + release.cer）
    //                        注意 1：keyAlias / storePassword / keyPassword
    //                              如果与 debug 不同，需要在 DevEco
    //                              "Project Structure → Signing Configs"
    //                              里重新生成并替换下方加密串
    //                        注意 2：上架时把 products[0].signingConfig 改成
    //                              "releaseConfig"，或在 DevEco 直接切换
    // ===========================================================
    "signingConfigs": [
      {
        "name": "default",
        "type": "HarmonyOS",
        "material": {
          "storeFile": "../certificates/1.p12",
          "storePassword": "0000001DFE90AD897E8CEB698E194B0A9F3FA113E6194D5BC88D06EC58F39FEE176DBA8C0F5AE08BBF0D14514C",
          "keyAlias": "test",
          "keyPassword": "0000001DBBF84AA06C058EBC479E51FC14073F80E036348CDEADE3A2ADD0ACCDD7CE25CAE0ACFF032A703CAF7F",
          "signAlg": "SHA256withECDSA",
          "profile": "C:/Users/21333/Documents/GitHub/team-project-26spring-26s-7/certificates/release_test_newRelease.p7b",
          "certpath": "C:/Users/21333/Documents/GitHub/team-project-26spring-26s-7/certificates/release_new.cer"
        }
      },
      {
        "name": "releaseConfig",
        "type": "HarmonyOS",
        "material": {
          "certpath": "../certificates/release_new.cer",
          "keyAlias": "test",
          "keyPassword": "0000001DA26E146E6C7493593840FE88CF46474683C3664E3CF2A854E3F84411F109DF2E4C2135EA2161D893C3",
          "profile": "../certificates/release_test_newRelease.p7b",
          "signAlg": "SHA256withECDSA",
          "storeFile": "../certificates/1.p12",
          "storePassword": "0000001D71C3B8B2163761B15D2E63CB1DAB529082038651DEE5ABA01607B722E09EE3918B22D90C9FD802C381"
        }
      }
    ],
    "products": [
      {
        "name": "default",
        // 当前指向 default（debug 流程用）；上架打包时改成 "releaseConfig"
        "signingConfig": "default",
        "compatibleSdkVersion": "5.0.5(17)",
        "targetSdkVersion": "5.0.5(17)",
        "runtimeOS": "HarmonyOS",
        "buildOption": {
          "strictMode": {
            "useNormalizedOHMUrl": true
          }
        }
      }
    ],
    "buildModeSet": [
      {
        "name": "debug"
      },
      {
        "name": "release"
      }
    ],
    "capabilities": [
      {
        "bundleName": "its.map.pin",
        "config": [
          {
            "name": "Push Kit",
            "capability": "com.huawei.service.push.base_service"
          },
          {
            "name": "Device status detection",
            "capability": "com.huawei.service.device_security.device_verify"
          },
          {
            "name": "Map Kit",
            "capability": "com.huawei.service.mapkit"
          },
          {
            "name": "Safety Detect",
            "capability": "com.huawei.service.device_security.safety_detect"
          }
        ]
      }
    ]
  },
  "modules": [
    {
      "name": "entry",
      "srcPath": "./entry",
      "targets": [
        {
          "name": "default",
          "applyToProducts": [
            "default"
          ]
        }
      ]
    }
  ]
}
