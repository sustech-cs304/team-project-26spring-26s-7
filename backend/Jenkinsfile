// Backend CI/CD for team-project-26spring-26s-7
// =============================================
// This Jenkinsfile lives at `backend/Jenkinsfile` and is consumed by the
// `team-project-backend-ci` job on the backend Jenkins server
// (root@139.159.143.195:8080).
//
// The frontend has its own Jenkinsfile at the repo root, running on a
// completely different Jenkins (zzh's Windows laptop, agent label "windows-zzh",
// triggered via a self-hosted GitHub Actions runner). The two Jenkins servers
// run in parallel and don't know about each other — both fire on every push
// to `main`, both post their own commit status check to the same commit.
//
// All sh blocks that operate on backend code are wrapped in `dir('backend')`
// so paths inside read as if the script were running from the backend/ root.
// $WORKSPACE / $STAGE_DIR / $CI_OUTPUT_DIR remain repo-root-relative or
// absolute, so artifact collection still works.

pipeline {
    agent any

    options {
        skipDefaultCheckout(false)
        skipStagesAfterUnstable()
        timeout(time: 30, unit: 'MINUTES')
        timestamps()
    }

    environment {
        // ---- CI server: backend Jenkins on root@139.159.143.195:8080 (Ubuntu 22.04 / Java 21 / Python 3.10).
        // Distinct artifact root from the standalone Backend_ItsMapPin job
        // (which uses /var/lib/jenkins/ci-artifacts/backend) — keep them isolated.
        CI_ARTIFACT_ROOT_DEFAULT = '/var/lib/jenkins/ci-artifacts/team-project-backend'
        PYTHON_BIN               = '/usr/bin/python3'

        // ---- Pip in 华为云 — use HuaweiCloud mirror (intra-provider speed) with TUNA fallback
        PIP_DISABLE_PIP_VERSION_CHECK = '1'
        PIP_NO_INPUT                  = '1'
        PYTHONDONTWRITEBYTECODE       = '1'
        PIP_INDEX_URL       = 'https://repo.huaweicloud.com/repository/pypi/simple/'
        PIP_EXTRA_INDEX_URL = 'https://pypi.tuna.tsinghua.edu.cn/simple'
        PIP_TRUSTED_HOST    = 'repo.huaweicloud.com pypi.tuna.tsinghua.edu.cn pypi.org files.pythonhosted.org'

        // Workspace-relative staging dir. Everything that needs to be picked up
        // by archiveArtifacts / junit MUST land here first (Jenkins refuses
        // absolute paths). After Archive stage we mirror this into CI_OUTPUT_DIR.
        STAGE_DIR = 'build-artifacts'

        // ---- GitHub commit status (distinct context from the standalone backend job)
        GH_REPO_URL    = 'https://github.com/sustech-cs304/team-project-26spring-26s-7'
        GH_REPO_API    = 'sustech-cs304/team-project-26spring-26s-7'
        GH_STATUS_CTX  = 'jenkins/team-project-backend-ci'
        GH_PAT_CRED_ID = 'github-status-token-team-project'

        // Banner style mirrors the frontend Jenkinsfile for visual consistency.
        ANSI_RESET  = '[0m'
        ANSI_GREEN  = '[32m'
        ANSI_RED    = '[31m'
        ANSI_YELLOW = '[33m'
        ANSI_CYAN   = '[36m'
    }

    stages {

        // ==============================================================
        stage('Checkout') {
            steps {
                script {
                    echo ''
                    echo '╔════════════════════════════════════════════════════════════════╗'
                    echo '║                   Stage: Checkout                              ║'
                    echo '╚════════════════════════════════════════════════════════════════╝'
                    echo ''
                    checkout scm
                    env.GIT_SHORT_SHA = sh(script: 'git rev-parse --short=8 HEAD', returnStdout: true).trim()
                    echo "Commit: ${env.GIT_SHORT_SHA}"
                    _setGitHubStatus('PENDING', "Build #${env.BUILD_NUMBER} in progress")
                }
            }
            post {
                success { script { _stageOk('CHECKOUT COMPLETED SUCCESSFULLY') } }
                failure { script { _stageFail('CHECKOUT FAILED') } }
            }
        }

        // ==============================================================
        stage('Prepare Outputs') {
            steps {
                script {
                    echo ''
                    echo '╔════════════════════════════════════════════════════════════════╗'
                    echo '║               Stage: Prepare Outputs                           ║'
                    echo '╚════════════════════════════════════════════════════════════════╝'
                    echo ''
                    def artifactRoot = env.LOCAL_ARTIFACT_ROOT?.trim() ?: env.CI_ARTIFACT_ROOT_DEFAULT
                    env.CI_OUTPUT_DIR = "${artifactRoot}/build-${env.BUILD_NUMBER}"
                    echo "Output (external):  ${env.CI_OUTPUT_DIR}"
                    echo "Staging (workspace): ${env.WORKSPACE}/${env.STAGE_DIR}"
                    sh '''
                        set -e
                        mkdir -p \
                          "$CI_OUTPUT_DIR" \
                          "$CI_OUTPUT_DIR/logs" \
                          "$CI_OUTPUT_DIR/reports" \
                          "$CI_OUTPUT_DIR/packages" \
                          "$CI_OUTPUT_DIR/metrics" \
                          "$CI_OUTPUT_DIR/meta"
                        rm -rf "$WORKSPACE/$STAGE_DIR"
                        mkdir -p \
                          "$WORKSPACE/$STAGE_DIR" \
                          "$WORKSPACE/$STAGE_DIR/logs" \
                          "$WORKSPACE/$STAGE_DIR/reports" \
                          "$WORKSPACE/$STAGE_DIR/packages" \
                          "$WORKSPACE/$STAGE_DIR/metrics" \
                          "$WORKSPACE/$STAGE_DIR/meta"

                        cat > "$WORKSPACE/$STAGE_DIR/meta/build-info.txt" <<EOF
Job Name:     $JOB_NAME
Build Number: $BUILD_NUMBER
Build URL:    $BUILD_URL
Workspace:    $WORKSPACE
Git Branch:   $GIT_BRANCH
Git Commit:   $GIT_SHORT_SHA
Started At:   $(date -Iseconds)
Hostname:     $(hostname)
Pipeline:     backend/Jenkinsfile (team-project)
EOF
                        cp "$WORKSPACE/$STAGE_DIR/meta/build-info.txt" "$CI_OUTPUT_DIR/meta/build-info.txt"
                    '''
                }
            }
            post {
                success { script { _stageOk("OUTPUT DIRECTORIES PREPARED: ${env.CI_OUTPUT_DIR}") } }
                failure { script { _stageFail('OUTPUT PREPARATION FAILED') } }
            }
        }

        // ==============================================================
        stage('Clean') {
            steps {
                script {
                    echo ''
                    echo '╔════════════════════════════════════════════════════════════════╗'
                    echo '║                    Stage: Clean                                ║'
                    echo '╚════════════════════════════════════════════════════════════════╝'
                    echo ''
                    dir('backend') {
                        sh '''
                            set -e
                            find . -type d -name __pycache__   -not -path "./.ci-venv/*" -prune -exec rm -rf {} + 2>/dev/null || true
                            find . -type d -name .pytest_cache -not -path "./.ci-venv/*" -prune -exec rm -rf {} + 2>/dev/null || true
                            find . -type d -name "*.egg-info"  -not -path "./.ci-venv/*" -prune -exec rm -rf {} + 2>/dev/null || true
                            rm -rf dist build .coverage htmlcov 2>/dev/null || true
                        '''
                    }
                }
            }
            post {
                success { script { _stageOk('CLEAN COMPLETED SUCCESSFULLY') } }
                failure { script { _stageFail('CLEAN FAILED') } }
            }
        }

        // ==============================================================
        stage('Install Dependencies') {
            steps {
                script {
                    echo ''
                    echo '╔════════════════════════════════════════════════════════════════╗'
                    echo '║            Stage: Install Dependencies                         ║'
                    echo '╚════════════════════════════════════════════════════════════════╝'
                    echo ''
                    dir('backend') {
                        sh '''#!/usr/bin/env bash
                            # Visible pip output via tee + pipefail (bash, not dash).
                            set -e -o pipefail
                            LOG="$WORKSPACE/$STAGE_DIR/logs/install-dependencies.log"
                            : > "$LOG"

                            # venv is in the backend/ subtree to keep it scoped + survive Clean stage
                            VENV="$WORKSPACE/backend/.ci-venv"
                            if [ ! -f "$VENV/bin/activate" ]; then
                                echo "[venv] (re)creating venv at $VENV" | tee -a "$LOG"
                                rm -rf "$VENV"
                                "$PYTHON_BIN" -m venv "$VENV" 2>&1 | tee -a "$LOG"
                                if [ ! -f "$VENV/bin/activate" ]; then
                                    echo "[venv] FATAL: python3 -m venv did not produce bin/activate" | tee -a "$LOG"
                                    echo "        Run on agent: apt install -y python3.10-venv" | tee -a "$LOG"
                                    exit 1
                                fi
                                VENV_FRESH=1
                            else
                                echo "[venv] reusing existing venv at $VENV" | tee -a "$LOG"
                                VENV_FRESH=0
                            fi
                            . "$VENV/bin/activate"
                            echo "[venv] python=$(python -V 2>&1)  pip=$(pip --version)" | tee -a "$LOG"

                            # Hash-based dep cache: skip pip install entirely when no requirements file changed.
                            REQS="ci/ci-requirements.txt ai-relay/requirements.txt sensitive-filter/requirements.txt picture-check/requirements.txt share-service/requirements.txt"
                            DEPS_HASH=$(sha256sum $REQS 2>/dev/null | sha256sum | awk '\''{print $1}'\'')
                            HASH_FILE="$VENV/.deps-hash"
                            CACHED_HASH=$(cat "$HASH_FILE" 2>/dev/null || echo "")

                            if [ "$VENV_FRESH" = "0" ] && [ "$DEPS_HASH" = "$CACHED_HASH" ] && [ -n "$DEPS_HASH" ]; then
                                echo "[pip] cache hit — deps hash matches last successful install, skipping pip install" | tee -a "$LOG"
                                echo "[pip] hash: $DEPS_HASH" | tee -a "$LOG"
                            else
                                echo "[pip] cache miss (fresh_venv=$VENV_FRESH cached=$CACHED_HASH new=$DEPS_HASH) — installing" | tee -a "$LOG"
                                PIP_OPTS="--disable-pip-version-check --retries 5 --timeout 120 --progress-bar off"

                                echo "" | tee -a "$LOG"
                                echo "[pip] (1/5) ci tooling" | tee -a "$LOG"
                                python -m pip install $PIP_OPTS -r ci/ci-requirements.txt 2>&1 | tee -a "$LOG"

                                i=1
                                for req in ai-relay/requirements.txt sensitive-filter/requirements.txt picture-check/requirements.txt share-service/requirements.txt; do
                                    i=$((i+1))
                                    if [ -f "$req" ]; then
                                        echo "" | tee -a "$LOG"
                                        echo "[pip] ($i/5) $req" | tee -a "$LOG"
                                        python -m pip install $PIP_OPTS -r "$req" 2>&1 | tee -a "$LOG"
                                    else
                                        echo "[pip] ($i/5) skip (not found): $req" | tee -a "$LOG"
                                    fi
                                done

                                echo "$DEPS_HASH" > "$HASH_FILE"
                                echo "[pip] cache key written: $DEPS_HASH" | tee -a "$LOG"
                            fi

                            python -m pip freeze > "$WORKSPACE/$STAGE_DIR/metrics/pip-freeze.txt"
                            echo "" | tee -a "$LOG"
                            echo "[done] dependencies ready ($(wc -l < "$WORKSPACE/$STAGE_DIR/metrics/pip-freeze.txt") packages installed)" | tee -a "$LOG"
                        '''
                    }
                }
            }
            post {
                success { script { _stageOk('DEPENDENCIES INSTALLED SUCCESSFULLY') } }
                failure { script { _stageFailLog('DEPENDENCY INSTALLATION FAILED', 'install-dependencies.log') } }
            }
        }

        // ==============================================================
        stage('Lint') {
            // Warn-only: report ruff findings but never break the build.
            steps {
                script {
                    echo ''
                    echo '╔════════════════════════════════════════════════════════════════╗'
                    echo '║                      Stage: Lint                               ║'
                    echo '║          (warn-only — does not fail the build)                 ║'
                    echo '╚════════════════════════════════════════════════════════════════╝'
                    echo ''
                    dir('backend') {
                        sh '''#!/usr/bin/env bash
                            set +e
                            . "$WORKSPACE/backend/.ci-venv/bin/activate"
                            LOG="$WORKSPACE/$STAGE_DIR/logs/lint.log"
                            : > "$LOG"

                            TARGETS="ai-relay sensitive-filter picture-check share-service ci"
                            echo "[lint] ruff check $TARGETS" | tee -a "$LOG"

                            ruff check --config ci/ruff.toml --output-format=concise $TARGETS 2>&1 | tee -a "$LOG"
                            rc=${PIPESTATUS[0]}
                            echo "[lint] ruff exit=$rc" | tee -a "$LOG"

                            ruff check --config ci/ruff.toml --output-format=github $TARGETS \
                                > "$WORKSPACE/$STAGE_DIR/reports/lint-ruff.txt" 2>/dev/null

                            exit 0
                        '''
                    }
                }
            }
            post {
                always {
                    script {
                        def lintLog = "${env.WORKSPACE}/${env.STAGE_DIR}/logs/lint.log"
                        def issues = sh(returnStdout: true,
                            script: "grep -cE ': [A-Z][0-9]+' '${lintLog}' 2>/dev/null || echo 0").trim()
                        echo ''
                        echo "${ANSI_CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${ANSI_RESET}"
                        if (issues == '0' || issues == '') {
                            echo "${ANSI_GREEN}✓ LINT CLEAN (no findings)${ANSI_RESET}"
                        } else {
                            echo "${ANSI_YELLOW}⚠ LINT: ~${issues} findings (warn-only — see ${env.STAGE_DIR}/logs/lint.log)${ANSI_RESET}"
                        }
                        echo "${ANSI_CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${ANSI_RESET}"
                        echo ''
                    }
                }
            }
        }

        // ==============================================================
        stage('Compile') {
            steps {
                script {
                    echo ''
                    echo '╔════════════════════════════════════════════════════════════════╗'
                    echo '║                    Stage: Compile                              ║'
                    echo '║         (python -m compileall — syntax check)                  ║'
                    echo '╚════════════════════════════════════════════════════════════════╝'
                    echo ''
                    dir('backend') {
                        sh '''
                            set -e
                            . "$WORKSPACE/backend/.ci-venv/bin/activate"
                            LOG="$WORKSPACE/$STAGE_DIR/logs/compile.log"
                            TARGETS="ai-relay sensitive-filter picture-check share-service ci"
                            echo "[compile] python -m compileall -q $TARGETS" | tee "$LOG"
                            python -m compileall -q $TARGETS 2>&1 | tee -a "$LOG"
                        '''
                    }
                }
            }
            post {
                success { script { _stageOk('COMPILATION COMPLETED SUCCESSFULLY') } }
                failure { script { _stageFailLog('COMPILATION FAILED', 'compile.log') } }
            }
        }

        // ==============================================================
        stage('Test') {
            steps {
                script {
                    echo ''
                    echo '╔════════════════════════════════════════════════════════════════╗'
                    echo '║                     Stage: Test                                ║'
                    echo '╚════════════════════════════════════════════════════════════════╝'
                    echo ''
                    dir('backend') {
                        sh '''#!/usr/bin/env bash
                            set -e -o pipefail
                            . "$WORKSPACE/backend/.ci-venv/bin/activate"
                            LOG="$WORKSPACE/$STAGE_DIR/logs/test.log"
                            : > "$LOG"

                            echo "==========================================" | tee -a "$LOG"
                            echo " (1/2) import smoke: ai-relay / sensitive-filter / picture-check" | tee -a "$LOG"
                            echo "==========================================" | tee -a "$LOG"
                            python ci/smoke_imports.py 2>&1 | tee -a "$LOG"

                            echo "" | tee -a "$LOG"
                            echo "==========================================" | tee -a "$LOG"
                            echo " (2/2) pytest: share-service" | tee -a "$LOG"
                            echo "==========================================" | tee -a "$LOG"

                            REPORTS="$WORKSPACE/$STAGE_DIR/reports"
                            cd share-service
                            python -m pytest share_service/tests \
                                -v -p no:cacheprovider \
                                --junitxml="$REPORTS/junit-share-service.xml" \
                                --cov=share_service \
                                --cov-report=term-missing \
                                --cov-report="xml:$REPORTS/coverage-share-service.xml" \
                                --cov-report="html:$REPORTS/coverage-share-service-html" \
                                2>&1 | tee -a "$LOG"
                        '''
                    }
                }
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: "${env.STAGE_DIR}/reports/junit-*.xml"
                }
                success { script { _stageOk('TESTS PASSED') } }
                failure { script { _stageFailLog('TESTS FAILED', 'test.log') } }
            }
        }

        // ==============================================================
        stage('Metrics') {
            steps {
                script {
                    echo ''
                    echo '╔════════════════════════════════════════════════════════════════╗'
                    echo '║               Stage: Collect Metrics                           ║'
                    echo '╚════════════════════════════════════════════════════════════════╝'
                    echo ''
                    dir('backend') {
                        sh '''
                            set -e
                            . "$WORKSPACE/backend/.ci-venv/bin/activate"
                            METRICS="$WORKSPACE/$STAGE_DIR/metrics"
                            mkdir -p "$METRICS"
                            TARGETS="ai-relay sensitive-filter picture-check share-service"

                            {
                              echo "==== Source file counts and lines of code ===="
                              total_files=0
                              total_lines=0
                              for t in $TARGETS; do
                                  files=$(find "$t" -name "*.py" -not -path "*/.ci-venv/*" -not -path "*/__pycache__/*" 2>/dev/null | wc -l)
                                  lines=$(find "$t" -name "*.py" -not -path "*/.ci-venv/*" -not -path "*/__pycache__/*" -exec cat {} + 2>/dev/null | wc -l)
                                  printf "  %-20s  files=%-4s  lines=%s\n" "$t" "$files" "$lines"
                                  total_files=$((total_files + files))
                                  total_lines=$((total_lines + lines))
                              done
                              echo "  ----------"
                              printf "  %-20s  files=%-4s  lines=%s\n" "TOTAL" "$total_files" "$total_lines"
                            } | tee "$METRICS/loc.txt"

                            {
                              echo ""
                              echo "==== Cyclomatic complexity (radon cc, average per service) ===="
                              for t in $TARGETS; do
                                  avg=$(radon cc -a -s "$t" 2>/dev/null | tail -1)
                                  printf "  %-20s  %s\n" "$t" "$avg"
                              done
                            } | tee -a "$METRICS/loc.txt"

                            radon cc $TARGETS -a -s > "$METRICS/cyclomatic-complexity.txt" 2>/dev/null || true
                            radon mi $TARGETS      > "$METRICS/maintainability-index.txt"  2>/dev/null || true
                            radon raw $TARGETS     > "$METRICS/raw-stats.txt"               2>/dev/null || true

                            {
                              echo "team-project backend CI metrics — build #$BUILD_NUMBER"
                              echo "Commit: $GIT_SHORT_SHA"
                              echo "Generated: $(date -Iseconds)"
                              echo ""
                              cat "$METRICS/loc.txt"
                              echo ""
                              echo "==== Top-level dependencies (pip-freeze excerpt) ===="
                              head -40 "$METRICS/pip-freeze.txt"
                            } > "$METRICS/summary.txt"

                            echo "[metrics] wrote $METRICS/summary.txt"
                        '''
                    }
                }
            }
            post {
                success { script { _stageOk('METRICS COLLECTED') } }
                failure { script { _stageFail('METRICS COLLECTION FAILED') } }
            }
        }

        // ==============================================================
        stage('Archive') {
            // Two tarballs:
            //   team-project-backend-<N>-<sha>.tar.gz       — code + reports + metrics + meta
            //   team-project-backend-<N>-<sha>-logs.tar.gz  — logs only
            steps {
                script {
                    echo ''
                    echo '╔════════════════════════════════════════════════════════════════╗'
                    echo '║                    Stage: Archive                              ║'
                    echo '╚════════════════════════════════════════════════════════════════╝'
                    echo ''
                    sh '''
                        set -e
                        STAGE="$WORKSPACE/$STAGE_DIR"
                        PKG="$STAGE/packages"
                        BUNDLE_BASE="team-project-backend-${BUILD_NUMBER}-${GIT_SHORT_SHA}"
                        CODE_TGZ="$PKG/${BUNDLE_BASE}.tar.gz"
                        LOG_TGZ="$PKG/${BUNDLE_BASE}-logs.tar.gz"
                        mkdir -p "$PKG"

                        # ---- code bundle: stage a clean tree then tar in one shot
                        SRC_STAGE="$STAGE/.code-stage"
                        rm -rf "$SRC_STAGE"
                        mkdir -p "$SRC_STAGE/backend"
                        DEST="$SRC_STAGE/backend"

                        # Copy source services + ci tooling from backend/
                        cp -r backend/ai-relay backend/sensitive-filter backend/picture-check backend/share-service backend/ci "$DEST/"
                        for f in backend/Jenkinsfile; do
                            [ -e "$f" ] && cp "$f" "$DEST/" || true
                        done

                        # Drop build artifacts (reports / metrics / meta) into the bundle
                        cp -r "$STAGE/reports" "$STAGE/metrics" "$STAGE/meta" "$DEST/" 2>/dev/null || true

                        echo "[archive] building $CODE_TGZ"
                        tar --exclude="**/__pycache__" \
                            --exclude="**/.pytest_cache" \
                            --exclude="**/.venv" \
                            --exclude="**/.ci-venv" \
                            -czf "$CODE_TGZ" \
                            -C "$SRC_STAGE" backend

                        echo "[archive] building $LOG_TGZ"
                        if [ -d "$STAGE/logs" ] && [ -n "$(ls -A "$STAGE/logs" 2>/dev/null)" ]; then
                            tar -czf "$LOG_TGZ" -C "$STAGE" logs
                        else
                            tar -czf "$LOG_TGZ" -C "$STAGE" --files-from /dev/null
                        fi

                        ( cd "$PKG" && sha256sum "${BUNDLE_BASE}.tar.gz" "${BUNDLE_BASE}-logs.tar.gz" \
                            > "${BUNDLE_BASE}.sha256.txt" )

                        rm -rf "$SRC_STAGE"

                        echo "[archive] DONE:"
                        ls -lh "$PKG"
                    '''
                    archiveArtifacts artifacts: "${env.STAGE_DIR}/packages/*.tar.gz, ${env.STAGE_DIR}/packages/*.sha256.txt",
                                     allowEmptyArchive: false, fingerprint: true
                }
            }
            post {
                success { script { _stageOk("ARTIFACTS ARCHIVED") } }
                failure { script { _stageFail('ARCHIVE FAILED') } }
            }
        }

    } // stages

    post {
        always {
            script {
                echo ''
                echo "${ANSI_CYAN}╔════════════════════════════════════════════════════════════════╗${ANSI_RESET}"
                echo "${ANSI_CYAN}║                    PIPELINE COMPLETED                          ║${ANSI_RESET}"
                echo "${ANSI_CYAN}╚════════════════════════════════════════════════════════════════╝${ANSI_RESET}"
                echo ''
                def statusColor = currentBuild.currentResult == 'SUCCESS' ? ANSI_GREEN : ANSI_RED
                echo "${statusColor}Build Status: ${currentBuild.currentResult}${ANSI_RESET}"
                env.CI_BUILD_RESULT = currentBuild.currentResult

                sh '''
                    set +e
                    if [ -n "$CI_OUTPUT_DIR" ] && [ -d "$WORKSPACE/$STAGE_DIR" ]; then
                        cp -r "$WORKSPACE/$STAGE_DIR/." "$CI_OUTPUT_DIR/" 2>/dev/null
                        cat >> "$CI_OUTPUT_DIR/meta/build-result.txt" <<EOF
Build Status: $CI_BUILD_RESULT
Finished At:  $(date -Iseconds)
EOF
                        find "$CI_OUTPUT_DIR" -type f -printf "%p\t%s\t%TY-%Tm-%Td %TH:%TM\n" \
                            > "$CI_OUTPUT_DIR/meta/artifact-manifest.txt"
                    fi
                    exit 0
                '''
                echo ''
                echo "Local outputs: ${env.CI_OUTPUT_DIR}"
                echo ''
            }
        }
        success {
            script {
                echo ''
                echo "${ANSI_CYAN}╔════════════════════════════════════════════════════════════════╗${ANSI_RESET}"
                echo "${ANSI_GREEN}║  ✓ BUILD SUCCESS!                                              ║${ANSI_RESET}"
                echo "${ANSI_GREEN}║  ${env.CI_OUTPUT_DIR}                                          ${ANSI_RESET}"
                echo "${ANSI_CYAN}╚════════════════════════════════════════════════════════════════╝${ANSI_RESET}"
                echo ''
                _setGitHubStatus('SUCCESS', "Build #${env.BUILD_NUMBER} passed (9 stages)")
            }
        }
        failure {
            script {
                echo ''
                echo "${ANSI_CYAN}╔════════════════════════════════════════════════════════════════╗${ANSI_RESET}"
                echo "${ANSI_RED}║  ✗ BUILD FAILED!                                               ║${ANSI_RESET}"
                echo "${ANSI_RED}║  Logs at: ${env.CI_OUTPUT_DIR}/logs                            ${ANSI_RESET}"
                echo "${ANSI_CYAN}╚════════════════════════════════════════════════════════════════╝${ANSI_RESET}"
                echo ''
                _setGitHubStatus('FAILURE', "Build #${env.BUILD_NUMBER} failed")
            }
        }
        unstable {
            script {
                _setGitHubStatus('FAILURE', "Build #${env.BUILD_NUMBER} unstable")
            }
        }
        aborted {
            script {
                _setGitHubStatus('ERROR', "Build #${env.BUILD_NUMBER} aborted")
            }
        }
    }
}

// ==================================================================
// helpers
// ==================================================================

def _stageOk(String msg) {
    echo ''
    echo "${env.ANSI_CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${env.ANSI_RESET}"
    echo "${env.ANSI_GREEN}✓ ${msg}${env.ANSI_RESET}"
    echo "${env.ANSI_CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${env.ANSI_RESET}"
    echo ''
}

def _stageFail(String msg) {
    echo ''
    echo "${env.ANSI_CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${env.ANSI_RESET}"
    echo "${env.ANSI_RED}✗ ${msg}${env.ANSI_RESET}"
    echo "${env.ANSI_CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${env.ANSI_RESET}"
    echo ''
}

// Direct curl to GitHub /statuses API. Bypasses GitHubCommitStatusSetter plugin
// because that plugin probes `GET /repos/{owner}/{name}` which requires full `repo`
// scope; direct POST only needs `repo:status`. Keep the PAT scope narrow.
//
// `state` ∈ {PENDING, SUCCESS, FAILURE, ERROR}
def _setGitHubStatus(String state, String message) {
    def sha = env.GIT_COMMIT ?: ''
    if (!sha) {
        echo "[github-status] !!! GIT_COMMIT not set yet, skipping (state=${state})"
        return
    }
    echo "[github-status] >>> posting state=${state} msg=\"${message}\" sha=${sha.take(8)}"

    String escMsg = (message ?: '').replace('\\', '\\\\').replace('"', '\\"').replace('\n', '\\n')
    String escUrl = (env.BUILD_URL ?: '').replace('\\', '\\\\').replace('"', '\\"')
    String payload = '{"state":"' + state.toLowerCase() + '",' +
                     '"context":"' + env.GH_STATUS_CTX + '",' +
                     '"description":"' + escMsg + '",' +
                     '"target_url":"' + escUrl + '"}'

    try {
        writeFile file: '.gh-status-payload.json', text: payload
        withCredentials([string(credentialsId: env.GH_PAT_CRED_ID, variable: 'GH_TOKEN')]) {
            sh """
                set +e
                code=\$(curl -sS -o .gh-status-resp.json -w '%{http_code}' \\
                    -X POST \\
                    -H "Authorization: token \${GH_TOKEN}" \\
                    -H 'Accept: application/vnd.github+json' \\
                    --data-binary @.gh-status-payload.json \\
                    'https://api.github.com/repos/${env.GH_REPO_API}/statuses/${sha}')
                if [ "\$code" = '201' ]; then
                    echo '[github-status] HTTP 201 — status posted ✓'
                else
                    echo "[github-status] HTTP \$code — API response:"
                    cat .gh-status-resp.json
                    echo
                fi
                rm -f .gh-status-payload.json .gh-status-resp.json
                exit 0
            """
        }
        echo "[github-status] <<< done (state=${state})"
    } catch (Throwable t) {
        echo "[github-status] !!! exception: ${t.class.name}: ${t.message}"
    }
}

def _stageFailLog(String msg, String logFile) {
    echo ''
    echo "${env.ANSI_CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${env.ANSI_RESET}"
    echo "${env.ANSI_RED}✗ ${msg}${env.ANSI_RESET}"
    echo "${env.ANSI_YELLOW}  Log: ${env.STAGE_DIR}/logs/${logFile}${env.ANSI_RESET}"
    echo "${env.ANSI_CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${env.ANSI_RESET}"
    sh """
        tail -n 80 '${env.WORKSPACE}/${env.STAGE_DIR}/logs/${logFile}' 2>/dev/null \
          || echo '(log file ${logFile} not produced)'
    """
    echo ''
}
