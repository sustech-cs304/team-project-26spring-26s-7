# =================================================================
# Backend_ItsMapPin —— 后端服务凭证集中配置
#
# 1. 复制为同目录下的 .env：     cp .env.example .env
# 2. 把下面的占位值替换成真实值
# 3. 启动脚本通过 `set -a; source .env; set +a` 注入环境变量子进程
#    这样凭证不会出现在 `ps aux` 里
#
# **不要 commit .env 文件**（.gitignore 已挡）
# =================================================================


# ----------------------------------------------------------------
# 1. ai-relay (port 8000) —— SiliconFlow Cloud 转发
# ----------------------------------------------------------------

# 客户端要带的 Bearer token，逗号分隔。空值 = 开放（仅 dev）
AI_SERVICE_API_KEYS=DEV_replace_me_with_random_string

# 每 token 每分钟最多请求数
AI_SERVICE_RATE_LIMIT_PER_MIN=30

# 单条 user 消息最大字符
AI_SERVICE_MAX_QUESTION_CHARS=3000

# **必填**：SiliconFlow API key。在 https://cloud.siliconflow.cn/account/ak 申请
SF_KEY=sk-replace-me-with-real-siliconflow-key


# ----------------------------------------------------------------
# 2. sensitive-filter (port 9100) —— 敏感词检测
# ----------------------------------------------------------------

SF_HOST=0.0.0.0
SF_PORT=9100

# 词表与白名单文件（一般用本仓库下相对路径，由 start_all.sh 注入绝对路径）
# SF_WORDS_FILE 和 SF_WHITELIST_FILE 不在此处写死，由 start_all.sh 计算

# 是否允许单字命中（默认禁，避免"日""杀"等大量误伤）
SF_ALLOW_SINGLE_CHAR=0

# 日志目录
SF_LOG_DIR=/data2/cse12310817/logs

# 鉴权（可选；空 = 开放模式）
# SENSITIVE_API_KEYS=
SENSITIVE_RATE_LIMIT=60/minute


# ----------------------------------------------------------------
# 3. picture-check (port 9200) —— 百度图片+文本审核
# ----------------------------------------------------------------

# **必填**：百度智能云控制台 → 内容审核 → 应用列表
BIC_API_KEY=replace-me
BIC_SECRET_KEY=replace-me

BIC_HOST=0.0.0.0
BIC_PORT=9200

# 鉴权（可选）
# BIC_API_KEYS=
BIC_RATE_LIMIT=30/minute
BIC_LOG_DIR=/data2/cse12310817/logs


# ----------------------------------------------------------------
# 4. share-service (port 8001) —— 分享链接 / 发布
# ----------------------------------------------------------------

# **必填**：HMAC 签名密钥。生成：
#   python -c "import secrets;print(secrets.token_urlsafe(32))"
SHARE_HMAC_KEY=replace-me-with-32-byte-random-string

# **必填**：CORS 白名单。本地放开就显式写 *
CORS_ORIGINS=*

# SQLite 路径（相对于 share-service/ 工作目录或绝对）
DB_PATH=./share.db

# 分享链接对外公开的 base URL（卡片中嵌入）。
# cloudflared 启动后填写其 trycloudflare URL。
SHARE_PUBLIC_BASE=https://share.travelpin.app

# AGC 对象存储签名 URL 的 mock base（dev mode）
MOCK_STORAGE_BASE=https://mock-storage.travelpin.app

# 是否启用 X-Dev-Uid 头替代真实 JWT（dev only）。生产**必须** = 0
ALLOW_DEV_UID_HEADER=1

# 高德地图 JS API（viewer_map.html / viewer_replay.html 用）
# 控制台：https://lbs.amap.com → 应用管理 → Web 端 (JS API)
AMAP_KEY=
AMAP_SECURITY_CODE=
