# 32-byte random key for HMAC signing of short links.
# Generate with:  python -c "import secrets;print(secrets.token_urlsafe(32))"
# Treat as a secret. Never commit the real value.
SHARE_HMAC_KEY=replace-me-with-a-32-byte-random-string

# SQLite database path (relative or absolute).
DB_PATH=./share.db

# Comma-separated CORS origins for the public §5.2 GET endpoint.
# Production should list only the AGC Hosting H5 origin.
CORS_ORIGINS=https://share.travelpin.app,http://localhost:5173

# Mock object-storage base URL — replaced with real AGC signed URLs once
# core/storage.py is rewired to the AGC SDK.
MOCK_STORAGE_BASE=https://mock-storage.travelpin.app

# Public origin returned in CreateShareResponse.url (and embedded in QR codes).
SHARE_PUBLIC_BASE=https://share.travelpin.app

# Set to "1" in dev/test only — allows X-Dev-Uid header to bypass JWT decoding.
ALLOW_DEV_UID_HEADER=0
