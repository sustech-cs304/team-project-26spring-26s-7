{
  "app": {
    // ===========================================================
    // signingConfigs:
    //   - "default"        ← 当前 debug / 真机调试用（testDebug.p7b + test.cer）
    //   - "releaseConfig"  ← AppGallery 上架打 release 包时切换到这个
    //                        （release_testRelease.p7b + release.cer）
    //                        注意 1：keyAlias / storePassword / keyPassword
    //                              如果与 debug 不同，需要在 DevEco
    //                              "Project Structure → Signing Configs"
    //                              里重新生成并替换下方加密串
    //                        注意 2：上架时把 products[0].signingConfig 改成
    //                              "releaseConfig"，或在 DevEco 直接切换
    // ===========================================================
    "signingConfigs": [
      {
        "name": "default",
        "type": "HarmonyOS",
        "material": {
          "certpath": "../certificates/test_new.cer",
          "keyAlias": "test",
          "keyPassword": "0000001D46AEE7BECDC3435F9BA877BEF78899CF537F625815675EA60AF332BD264E34E4CE6482F44BFAECB72A",
          "profile": "../certificates/test_newDebug.p7b",
          "signAlg": "SHA256withECDSA",
          "storeFile": "../certificates/1.p12",
          "storePassword": "0000001DE4CDE13220B6018FEAD18389527CF700F9D2738AB17CB6C905E7FDFC6C3A7759074C116EA87CB50938"
        }
      },
      {
        "name": "releaseConfig",
        "type": "HarmonyOS",
        "material": {
          "certpath": "../certificates/release_new.cer",
          "keyAlias": "test",
          "keyPassword": "0000001D350E36DAD77B0FB926AADCD582855788ABEDCE507B380CA78EFCF6D7B12546B892B2925C065523FAA3",
          "profile": "../certificates/release_test_newRelease.p7b",
          "signAlg": "SHA256withECDSA",
          "storeFile": "../certificates/1.p12",
          "storePassword": "0000001D70548735FE8598ADF5BF421F11A624F8F92973DF077F0F5364316230D1D8A07B3BBB28CED741ECBFB3"
        }
      }
    ],
    "products": [
      {
        "name": "default",
        // 当前指向 default（debug 流程用）；上架打包时改成 "releaseConfig"
        "signingConfig": "default",
        "compatibleSdkVersion": "5.0.5(17)",
        "targetSdkVersion": "5.0.5(17)",
        "runtimeOS": "HarmonyOS",
        "buildOption": {
          "strictMode": {
            "useNormalizedOHMUrl": true
          }
        }
      }
    ],
    "buildModeSet": [
      {
        "name": "debug"
      },
      {
        "name": "release"
      }
    ],
    "capabilities": [
      {
        "bundleName": "its.map.pin",
        "config": [
          {
            "name": "Push Kit",
            "capability": "com.huawei.service.push.base_service"
          },
          {
            "name": "Device status detection",
            "capability": "com.huawei.service.device_security.device_verify"
          },
          {
            "name": "Map Kit",
            "capability": "com.huawei.service.mapkit"
          },
          {
            "name": "Safety Detect",
            "capability": "com.huawei.service.device_security.safety_detect"
          }
        ]
      }
    ]
  },
  "modules": [
    {
      "name": "entry",
      "srcPath": "./entry",
      "targets": [
        {
          "name": "default",
          "applyToProducts": [
            "default"
          ]
        }
      ]
    }
  ]
}
