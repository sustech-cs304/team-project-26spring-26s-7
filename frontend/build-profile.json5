          "keyAlias": "test",
          "keyPassword": "0000001D0CEA156ECF4F60C74DA614F776371BBFDB61A638C0225E4824AD9FD9422B7002670E486E3766F3A12D",
          "signAlg": "SHA256withECDSA",
          "profile": "../certificates/testDebug.p7b",
